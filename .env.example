# 🥷 Stealth Browser Skill — Environment Variables
# Copy this to .env and fill in your values

# Proxy for Tier-2 operations (residential proxy recommended)
# PROXY=http://user:pass@residential-host:port
# GEOIP=1

# Probe output directory (default: /tmp/cloak-probe)
# OUT=/tmp/cloak-probe

# Run headed under Xvfb
# XVFB=1